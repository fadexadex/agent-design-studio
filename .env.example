# Agent Design Studio - Environment Variables

# =============================================================================
# API Keys (Required)
# =============================================================================

# Gemini API Key for AI code generation
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# Redis Configuration (Required for Director-Agent Architecture)
# =============================================================================

# Redis Cloud Configuration
REDIS_HOST=your_host
REDIS_PORT=your_port
REDIS_USERNAME=default
REDIS_PASSWORD=your_password
REDIS_DB=0

# =============================================================================
# Server Configuration (Optional)
# =============================================================================

# Server port (default: 3001)
PORT=3001

# Node environment (development, production, test)
NODE_ENV=development

# =============================================================================
# Frontend Configuration (Optional)
# =============================================================================

# Backend API URL for frontend (default: http://localhost:3001)
# In development with Vite proxy, this can be omitted (relative URLs work).
# Set this when running frontend and backend on different hosts/ports.
VITE_API_URL=http://localhost:3001
