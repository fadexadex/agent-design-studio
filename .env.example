# Agent Design Studio - Environment Variables

# =============================================================================
# API Keys (Required)
# =============================================================================

# Gemini API Key for AI code generation
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# Redis Configuration (Required for Director-Agent Architecture)
# =============================================================================

# Option 1: Redis URL (for cloud/production)
# REDIS_URL=redis://username:password@host:port

# Option 2: Individual settings (for local/development)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# Server Configuration (Optional)
# =============================================================================

# Server port (default: 3001)
PORT=3001

# Node environment (development, production, test)
NODE_ENV=development
